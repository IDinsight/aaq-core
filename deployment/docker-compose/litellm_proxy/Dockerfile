FROM ghcr.io/berriai/litellm:main-v1.34.6

ARG OPENAI_API_KEY
ENV OPENAI_API_KEY=$OPENAI_API_KEY

ARG GCP_CREDENTIALS
ENV GOOGLE_APPLICATION_CREDENTIALS=$GCP_CREDENTIALS

ARG GCP_PROJECT_ID
ARG GCP_LOCATION
ENV GCP_PROJECT_ID=$GCP_PROJECT_ID
ENV GCP_LOCATION=$GCP_LOCATION

COPY ./litellm_proxy_config.yaml /app/config.yaml

CMD ["--port", "4000", "--config", "/app/config.yaml"]
